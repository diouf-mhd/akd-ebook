{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/admin",
      "dest": "/admin.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}